{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "bio": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Service": {
      "title": "Marketplace Service",
      "description": "Details of the services offered by sellers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "city": { "type": "string" },
        "price": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["COD", "Voucher"] },
        "images": { "type": "array" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "description", "category", "city", "price"]
    },
    "Booking": {
      "title": "Service Booking",
      "description": "Tracks transactions between customers and sellers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "sellerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceTitle": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "bookingDate": { "type": "string", "format": "date-time" },
        "appointmentTime": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "voucherCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "sellerId", "serviceId", "status", "bookingDate"]
    },
    "Review": {
      "title": "Service Review",
      "description": "User reviews for completed services.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceId": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceId", "customerId", "rating", "comment"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Collection of app users."
    },
    "services": {
      "schema": "Service",
      "description": "Collection of services listed by sellers."
    },
    "bookings": {
      "schema": "Booking",
      "description": "Collection of bookings made by customers."
    },
    "reviews": {
      "schema": "Review",
      "description": "Collection of reviews for services."
    }
  }
}
