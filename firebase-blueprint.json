{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the ServLink platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "city": { "type": "string" },
        "address": { "type": "string" },
        "bio": { "type": "string" },
        "profilePic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "city", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "A service offered by a seller.",
      "type": "object",
      "properties": {
        "serviceId": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "city": { "type": "string" },
        "paymentType": { "type": "string", "enum": ["COD", "Voucher"] },
        "imageUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceId", "sellerId", "title", "category", "price", "city", "paymentType", "isVerified"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking made by a customer.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "customerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "paymentMethod": { "type": "string" },
        "voucherCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "customerId", "sellerId", "serviceId", "date", "status", "paymentMethod"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a service.",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "serviceId": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["reviewId", "serviceId", "customerName", "rating", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Service listings."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Service bookings."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Service reviews."
    }
  }
}
