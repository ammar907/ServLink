rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
       return isSignedIn() && (
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         (request.auth.token.email == 'ammarzia0031@gmail.com')
       );
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['customer', 'seller', 'admin'];
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
        isValidUser(incoming()) &&
        incoming().uid == userId &&
        incoming().role != 'admin'; // Cannot self-assign admin
      allow update: if (isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'city', 'address', 'bio', 'profilePic'])) ||
        isAdmin();
      allow delete: if isAdmin();
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if true; 
      allow create: if isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller' &&
        incoming().sellerId == request.auth.uid &&
        incoming().isVerified == false;
      allow update: if (isSignedIn() && (
        (existing().sellerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'description', 'price', 'city', 'paymentType', 'imageUrl'])) ||
        (isAdmin())
      ));
      allow delete: if isAdmin() || (isSignedIn() && existing().sellerId == request.auth.uid);
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.sellerId == request.auth.uid));
      allow create: if isSignedIn() && 
        incoming().customerId == request.auth.uid &&
        exists(/databases/$(database)/documents/services/$(incoming().serviceId));
      allow update: if (isSignedIn() && (
        (resource.data.sellerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        (resource.data.customerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && existing().status == 'pending') ||
        isAdmin()
      ));
      allow delete: if isAdmin();
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && 
        incoming().keys().hasAll(['reviewId', 'serviceId', 'customerName', 'rating', 'timestamp']) &&
        incoming().rating >= 1 && incoming().rating <= 5;
      allow delete: if isAdmin();
    }
  }
}
